PORT=3000
NODE_ENV=development

# Summarization LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Nevermined (required when PAYMENT_PROVIDER=nevermined)
PAYMENT_PROVIDER=dummy
NVM_API_KEY=
NVM_ENVIRONMENT=sandbox
NVM_PLAN_ID=
NVM_AGENT_ID=

# Dummy provider
DUMMY_API_KEY=dev-textweb-key

# Caching
REDIS_URL=
IN_MEMORY_CACHE_SIZE=500
CACHE_TTL_SECONDS=1800

# Limits / security
REQUEST_TIMEOUT_MS=30000
OPENAI_TIMEOUT_MS=20000
MAX_REQUEST_BYTES=1048576
MAX_URL_LENGTH=2048
MAX_RENDER_CHARS=30000
MAX_FOLLOW_LINKS=3
MAX_RESPONSE_CHARS=12000
MAX_SCHEMA_BYTES=32768
DNS_LOOKUP_TIMEOUT_MS=3000
URL_ALLOWLIST=
BLOCK_PRIVATE_NETWORKS=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Optional HTTPS (set both key and cert to enable direct TLS)
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=
HTTPS_CA_PATH=
