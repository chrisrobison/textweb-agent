{
  "name": "textweb-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Nevermined-metered TextWeb seller agent for web rendering, extraction, and summarization",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && npm run -w @textweb/client build",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "demo:smoke": "bash ./scripts/demo-smoke.sh"
  },
  "dependencies": {
    "@nevermined-io/payments": "1.1.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.7.0",
    "lru-cache": "^10.4.3",
    "openai": "^4.87.3",
    "textweb": "^0.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
